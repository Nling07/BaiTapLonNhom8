<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="501.0" prefWidth="926.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.btl.n8.Controller.sellController">
    <children>

        <!-- Return button -->
        <Button layoutX="871.0" layoutY="-1.0" onAction="#Return" prefHeight="30.0" prefWidth="90.0" text="← Return" />

        <!-- Background -->
        <ImageView fitHeight="533.0" fitWidth="968.0" layoutY="-1.0" mouseTransparent="true" pickOnBounds="true" preserveRatio="true" AnchorPane.rightAnchor="-6.0">
            <image><Image url="@../images/bidhome.png" /></image>
        </ImageView>

        <!-- FORM CARD (left) -->
        <Label layoutX="30.0" layoutY="65.0" text="List a new item" textFill="WHITE">
            <font><Font name="Press Start 2P" size="11.0" /></font>
        </Label>

        <Label layoutX="30.0" layoutY="100.0" text="Item name" textFill="WHITE">
            <font><Font name="Press Start 2P" size="9.0" /></font>
        </Label>
        <TextField fx:id="nameField" layoutX="30.0" layoutY="118.0" prefHeight="34.0" prefWidth="280.0" promptText="e.g. Naruto Poster Vol.1" />

        <Label layoutX="30.0" layoutY="162.0" text="Type" textFill="WHITE">
            <font><Font name="Press Start 2P" size="9.0" /></font>
        </Label>
        <ComboBox fx:id="typeCombo" layoutX="30.0" layoutY="180.0" prefHeight="34.0" prefWidth="280.0" />

        <Label layoutX="30.0" layoutY="224.0" text="Starting price (₫)" textFill="WHITE">
            <font><Font name="Press Start 2P" size="9.0" /></font>
        </Label>
        <TextField fx:id="priceField" layoutX="30.0" layoutY="242.0" prefHeight="34.0" prefWidth="280.0" promptText="e.g. 100000" />

        <Label layoutX="30.0" layoutY="286.0" text="Product image" textFill="WHITE">
            <font><Font name="Press Start 2P" size="9.0" /></font>
        </Label>
        <Button fx:id="uploadBtn" layoutX="30.0" layoutY="304.0" onAction="#handleUpload" prefHeight="60.0" prefWidth="280.0" text="↑ Click to upload image" />

        <Label fx:id="uploadLabel" layoutX="30.0" layoutY="370.0" prefWidth="280.0" text="" textFill="WHITE">
            <font><Font name="Press Start 2P" size="8.0" /></font>
        </Label>

        <Label fx:id="messageLabel" layoutX="30.0" layoutY="395.0" prefWidth="280.0" text="" textFill="RED">
            <font><Font name="Press Start 2P" size="8.0" /></font>
        </Label>

        <Button fx:id="submitBtn" layoutX="30.0" layoutY="425.0" onAction="#handleSell" prefHeight="36.0" prefWidth="280.0" text="+ List Item" />

        <!-- TABLE (right) -->
        <Label layoutX="340.0" layoutY="65.0" text="My listed items" textFill="WHITE">
            <font><Font name="Press Start 2P" size="11.0" /></font>
        </Label>

        <TableView fx:id="myItemTable" layoutX="321.0" layoutY="85.0" prefHeight="390.0" prefWidth="634.0" stylesheets="@../css/style.css">
            <columns>
                <TableColumn fx:id="colId" prefWidth="64.79998779296875" text="ID" />
                <TableColumn fx:id="colName" prefWidth="157.60006713867188" text="Item name" />
                <TableColumn fx:id="colType" prefWidth="77.5999755859375" text="Type" />
                <TableColumn fx:id="colStartPrice" prefWidth="123.199951171875" text="Start price" />
                <TableColumn fx:id="colCurrentPrice" prefWidth="134.39990234375" text="Current Price" />
                <TableColumn fx:id="colStatus" prefWidth="85.60009765625" text="Status" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
